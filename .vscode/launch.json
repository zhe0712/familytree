{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "FamilyTree: Chrome Debug (LAN)",
      "type": "pwa-chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}",
      "preLaunchTask": "vite: dev host",
      "sourceMaps": true,
      "trace": false
    },
    {
      "name": "FamilyTree: Start Dev Server Only (LAN)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev:host",
      "cwd": "${workspaceFolder}"
    }
  ]
}
