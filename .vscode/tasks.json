{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "vite: dev host",
      "type": "shell",
      "command": "npm run dev:host",
      "isBackground": true,
      "problemMatcher": [
        {
          "owner": "custom",
          "pattern": {
            "regexp": ".*"
          },
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*",
            "endsPattern": "(Local:|ready in)"
          }
        }
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    }
  ]
}
